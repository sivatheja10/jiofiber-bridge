# Copy to bridge.env and fill in. Sourced by scripts/register.sh.
# Get SIP_* values by running jfc_configure.py with logging (see README §5) — it prints
# realm / username / userpwd from the router. Do NOT commit bridge.env (it has your identity).

# --- Identity (from your JioFiber line, via jfc_configure.py) ---
SIP_PUBLIC_ID="sip:+<CC><NUMBER>@<CIRCLE>.wln.ims.jio.com"   # WITH the + ; <CIRCLE> is your service-area code
SIP_AUTH_USER="<CC><NUMBER>@<CIRCLE>.wln.ims.jio.com"        # NO +
SIP_REALM="<CIRCLE>.wln.ims.jio.com"                         # whatever realm jfc_configure.py reports
REGISTRAR="sip:jiofiber.local.html:5068;transport=tls"       # the router; leave as-is on most JioFiber setups
export SIP_PUBLIC_ID SIP_REALM REGISTRAR

# --- Device identity ---
# Pick a hostname the router has NEVER seen so the first-time OTP whitelisting triggers (see README §5).
DEVICE_HOST="MyJioBridge"
ROUTER_IP="192.168.29.1"          # your JioFiber router's LAN IP

# --- Overlay network (Tailscale/WireGuard between the bridge host and Asterisk) ---
BRIDGE_OVERLAY_IP="100.x.x.x"     # this host's overlay IP
ASTERISK_OVERLAY_IP="100.y.y.y"   # Asterisk's overlay IP

# --- Paths (adjust TARGET to your build's triple, e.g. x86_64-unknown-linux-gnu) ---
BASE="/opt/jiofiber-bridge"
BIN="$BASE/pjproject/pjsip-apps/bin/samples/x86_64-unknown-linux-gnu/jio_b2bua"
JFC="$BASE/jfc_configure.py"

# --- Alerting (optional) ---
NTFY_TOPIC=""                     # e.g. https://ntfy.sh/your-unique-random-topic  (empty = no alerts)
